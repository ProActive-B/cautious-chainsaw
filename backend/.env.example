# Copy to backend/.env and fill in for Phase 2 live feeds. Never commit .env.

# FAA NOTAM / FNS API (TFR + NOTAM geometry)
# FAA_NOTAM_API_KEY=

# OpenSky Network (live ADS-B) — free account
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=

# Rules DB version label shown in report footers
# RULES_DB_VERSION=2026.06-mvp
